{
  "outputDirectory": "frontend/dist",
  "env": {
    "UV_LINK_MODE": "copy"
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://typerek-production.up.railway.app/api/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
