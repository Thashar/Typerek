# Supabase PostgreSQL (prod) — skopiuj z: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[TWOJE-HASLO]@db.[TWOJ-PROJECT-REF].supabase.co:5432/postgres

# Lokalnie mozesz uzyc SQLite:
# DATABASE_URL=sqlite:///./typerek.db

SECRET_KEY=zmien-na-losowy-sekret-min-32-znaki
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Dowolny losowy ciag - musi byc rowniez ustawiony w Vercel > Settings > Cron Job Secret
CRON_SECRET=zmien-na-losowy-sekret

# dashboard.api-football.com (bezposrednie):
API_FOOTBALL_KEY=twoj-klucz
API_FOOTBALL_VIA_RAPIDAPI=false

# Jesli uzywasz RapidAPI zamiast bezposredniego:
# API_FOOTBALL_VIA_RAPIDAPI=true
